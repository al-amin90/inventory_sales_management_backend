# Environment example for Inventory & Sales Management Backend
# Copy to .env and fill values before running the app

# App
NODE_ENV=development
PORT=8000

# Database (MongoDB connection string)
DATABASE_URL=mongodb://localhost:27017/inventory_db

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# JWT secrets and expirations
JWT_ACCESS_TOKEN=your_access_token_secret
JWT_REFRESH_TOKEN=your_refresh_token_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (optional, used for uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
